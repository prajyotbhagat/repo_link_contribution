# =====================
# Required
# =====================
DJANGO_SECRET_KEY=your_secret_here
GITHUB_TOKEN=your_github_token_here
DJANGO_SETTINGS_MODULE=config.settings_prod
APP_BASE_URL=https://your-project.vercel.app

# =====================
# Database (PostgreSQL / Neon / Supabase / Railway)
# =====================
POSTGRES_DB=reporadar
POSTGRES_USER=reporadar
POSTGRES_PASSWORD=your_password
DATABASE_URL=your_database_url_here

# =====================
# Redis
# =====================
REDIS_URL=your_redis_url_here

# =====================
# Email notifications (Resend SMTP — https://resend.com/docs/send-with-smtp)
# All five vars below are REQUIRED for emails to be delivered in production.
# Without EMAIL_HOST_PASSWORD, Django silently uses console.EmailBackend.
# =====================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx  # ← your Resend API key
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=RepoRadar <noreply@yourdomain.com>

# =====================
# Django
# =====================
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app,https://your-domain.com
